#!/usr/bin/env python3
"""Save and restore wezterm tab layouts.

Usage:
    wez-tabs save [FILE]        Save current layout (default: ~/.config/wezterm/tabs.json)
    wez-tabs restore [FILE]     Restore layout from file
    wez-tabs show [FILE]        Show saved layout summary
    wez-tabs save --stdout      Print to stdout instead of file

The save captures tab titles, pane positions, working directories,
and running processes. The restore recreates the layout and
relaunches detected AI agents (claude, codex, opencode, gemini).
"""
import argparse
import json
import os
import subprocess
import sys
import time

DEFAULT_PATH = os.path.expanduser("~/.config/wezterm/tabs.json")
AGENTS = {"claude", "codex", "opencode", "gemini"}
SHELLS = {"-zsh", "zsh", "bash", "-bash", "fish", "sh", "dash"}


def cli(*args):
    cmd = ["wezterm", "cli"] + list(args)
    r = subprocess.run(cmd, capture_output=True, text=True, timeout=10)
    if r.returncode != 0:
        print(f"  warn: {' '.join(cmd)}: {r.stderr.strip()}", file=sys.stderr)
        return ""
    return r.stdout.strip()


def get_pane_procs(tty_name):
    pts = tty_name.replace("/dev/", "") if tty_name else ""
    if not pts:
        return []
    try:
        r = subprocess.run(
            ["ps", "-t", pts, "-o", "args", "--no-headers"],
            capture_output=True, text=True, timeout=3,
        )
        return [l.strip() for l in r.stdout.strip().split("\n") if l.strip()]
    except Exception:
        return []


def save(path=None, stdout=False):
    raw = cli("list", "--format", "json")
    if not raw:
        print("Error: could not list panes", file=sys.stderr)
        sys.exit(1)

    panes = json.loads(raw)
    tabs = {}

    for p in panes:
        tid = p["tab_id"]
        if tid not in tabs:
            tabs[tid] = {
                "tab_title": p["tab_title"],
                "workspace": p.get("workspace", "default"),
                "panes": [],
            }

        procs = get_pane_procs(p.get("tty_name", ""))
        interesting = [
            proc for proc in procs
            if proc.split("/")[-1].split()[0] not in SHELLS
        ]

        cwd = p.get("cwd", "")
        if cwd.startswith("file://"):
            cwd = "/" + cwd.split("/", 3)[-1] if "/" in cwd[7:] else cwd

        tabs[tid]["panes"].append({
            "left_col": p["left_col"],
            "top_row": p["top_row"],
            "cols": p["size"]["cols"],
            "rows": p["size"]["rows"],
            "cwd": cwd,
            "procs": interesting,
            "is_active": p.get("is_active", False),
        })

    result = []
    for tid in sorted(tabs.keys()):
        tab = tabs[tid]
        tab["panes"].sort(key=lambda p: (p["top_row"], p["left_col"]))
        result.append(tab)

    output = json.dumps(result, indent=2) + "\n"

    if stdout:
        sys.stdout.write(output)
    else:
        path = path or DEFAULT_PATH
        os.makedirs(os.path.dirname(path), exist_ok=True)
        with open(path, "w") as f:
            f.write(output)
        n_tabs = len(result)
        n_panes = sum(len(t["panes"]) for t in result)
        n_agents = sum(
            1 for t in result for p in t["panes"]
            for proc in p.get("procs", [])
            if proc.split("/")[-1].split()[0] in AGENTS
        )
        print(f"Saved {n_tabs} tabs, {n_panes} panes, {n_agents} agents → {path}",
              file=sys.stderr)


def restore(path=None):
    path = path or DEFAULT_PATH
    if path == "-":
        data = json.load(sys.stdin)
    else:
        with open(path) as f:
            data = json.load(f)

    print(f"Restoring {len(data)} tabs from {path}...", file=sys.stderr)

    for tab in data:
        title = tab["tab_title"]
        panes = tab["panes"]
        if not panes:
            continue

        first = panes[0]
        cwd = first.get("cwd", "") or os.path.expanduser("~")

        # Spawn first pane
        pane_id = cli("spawn", "--cwd", cwd)
        if not pane_id:
            print(f"  FAIL: could not create tab '{title}'", file=sys.stderr)
            continue
        pane_id = pane_id.strip()
        cli("set-tab-title", "--pane-id", pane_id, title)

        created = [(pane_id, first)]

        # Create splits for remaining panes
        for pane in panes[1:]:
            pane_cwd = pane.get("cwd", "") or cwd

            # Infer split direction from position
            if pane["left_col"] > first["left_col"]:
                direction = "--right"
            else:
                direction = "--bottom"

            # Calculate percentage
            total_w = max(p["left_col"] + p["cols"] for p in panes)
            total_h = max(p["top_row"] + p["rows"] for p in panes)
            if direction == "--right":
                pct = max(10, min(90, int(100 * pane["cols"] / total_w)))
            else:
                pct = max(10, min(90, int(100 * pane["rows"] / total_h)))

            # Split from the most recently created pane that's on the
            # correct side
            split_from = pane_id
            for pid, pdata in created:
                if direction == "--right" and pdata["left_col"] < pane["left_col"]:
                    split_from = pid
                elif direction == "--bottom" and pdata["top_row"] < pane["top_row"]:
                    split_from = pid

            new_id = cli("split-pane", direction, "--percent", str(pct),
                        "--cwd", pane_cwd, "--pane-id", split_from)
            if new_id:
                created.append((new_id.strip(), pane))
            else:
                print(f"  warn: split failed in tab '{title}'", file=sys.stderr)

        # Relaunch agents
        for pid, pane in created:
            for proc_cmd in pane.get("procs", []):
                binary = proc_cmd.split("/")[-1].split()[0]
                if binary in AGENTS:
                    # Use the full command line to preserve flags
                    print(f"  {title}/{pid}: {binary}", file=sys.stderr)
                    cli("send-text", "--pane-id", pid, "--no-paste",
                        f"{proc_cmd}\r")
                    time.sleep(0.3)
                    break

        n = len(created)
        print(f"  {title}: {n} pane{'s' if n != 1 else ''}", file=sys.stderr)

    print(f"Done.", file=sys.stderr)


def show(path=None):
    path = path or DEFAULT_PATH
    with open(path) as f:
        data = json.load(f)

    for tab in data:
        title = tab["tab_title"]
        panes = tab["panes"]
        agents = []
        for p in panes:
            for proc in p.get("procs", []):
                b = proc.split("/")[-1].split()[0]
                if b in AGENTS:
                    agents.append(b)

        agent_str = ", ".join(agents) if agents else "-"
        cwds = set()
        for p in panes:
            c = p.get("cwd", "")
            if c:
                cwds.add(c.rstrip("/").split("/")[-1])
        cwd_str = ", ".join(sorted(cwds)) if cwds else "-"

        print(f"  {title:>15}: {len(panes)} panes  agents=[{agent_str}]  dirs=[{cwd_str}]")

    total_panes = sum(len(t["panes"]) for t in data)
    total_agents = sum(
        1 for t in data for p in t["panes"]
        for proc in p.get("procs", [])
        if proc.split("/")[-1].split()[0] in AGENTS
    )
    print(f"\n  {len(data)} tabs, {total_panes} panes, {total_agents} agents")


def main():
    parser = argparse.ArgumentParser(
        prog="wez-tabs",
        description="Save and restore wezterm tab layouts",
    )
    sub = parser.add_subparsers(dest="command")

    p_save = sub.add_parser("save", help="Save current layout")
    p_save.add_argument("file", nargs="?", help=f"Output file (default: {DEFAULT_PATH})")
    p_save.add_argument("--stdout", action="store_true", help="Print to stdout")

    p_restore = sub.add_parser("restore", help="Restore layout from file")
    p_restore.add_argument("file", nargs="?", help=f"Input file (default: {DEFAULT_PATH})")

    p_show = sub.add_parser("show", help="Show saved layout summary")
    p_show.add_argument("file", nargs="?", help=f"Input file (default: {DEFAULT_PATH})")

    args = parser.parse_args()

    if args.command == "save":
        save(args.file, stdout=args.stdout)
    elif args.command == "restore":
        restore(args.file)
    elif args.command == "show":
        show(args.file)
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
