# Maintainer:  Wez Furlong <wez at wezfurlong dot org>
# NOTE: if you're looking at this on AUR, this file is generated from
# https://github.com/wakamex/wakterm/blob/main/ci/PKGBUILD.template
# by automation in the wakterm repo.

pkgname=wakterm-bin
_tag=@TAG@
pkgver=$(echo $_tag | tr - .)
pkgrel=2
pkgdesc='A GPU-accelerated cross-platform terminal emulator and multiplexer implemented in Rust'
arch=('i686' 'x86_64')
url='https://wakterm.org'
license=('MIT')
provides=('wakterm')
conflicts=('wakterm')
# Don't strip: it will break the binary and it only saves ~10% anyway
options=('!strip')
makedepends=('fuse')
depends=(
  'dbus'
  'fontconfig'
  'hicolor-icon-theme'
  'libx11'
  'libxkbcommon-x11'
  'wayland'
  'xcb-util-keysyms'
  'xcb-util-wm'
)
optdepends=(
  'python-nautilus: wakterm context menu in Nautilus'
)
source=(
  "wakterm::https://github.com/wakamex/wakterm/releases/download/${_tag}/wakterm-${_tag}-Ubuntu16.04.AppImage"
  'LICENSE::https://github.com/wakamex/wakterm/raw/main/LICENSE.md'
)
sha256sums=(
  '@SHA256@'
  'ad915d9508677a4e94e4b3c0a045fedd20e953d95d7cd3ec97e6d16840fa0ed5'
)

prepare() {
  chmod +x "${srcdir}/wakterm"
}

pkgver() {
  "${srcdir}/wakterm" --version | cut -d' ' -f2 | tr - .
}

build() {
  "${srcdir}/wakterm" --appimage-extract >/dev/null
}

package() {
  install -Dm755 squashfs-root/usr/bin/wakterm -t "${pkgdir}/usr/bin/"
  install -Dm755 squashfs-root/usr/bin/wakterm-gui -t "${pkgdir}/usr/bin/"
  install -Dm755 squashfs-root/usr/bin/wakterm-mux-server -t "${pkgdir}/usr/bin/"
  install -Dm644 LICENSE -t "${pkgdir}/usr/share/licenses/${pkgname}"
  install -Dm644 squashfs-root/usr/share/icons/hicolor/128x128/apps/org.wezfurlong.wakterm.png \
                 "${pkgdir}/usr/share/icons/hicolor/128x128/apps/org.wezfurlong.wakterm.png"
  install -Dm644 squashfs-root/usr/share/applications/org.wezfurlong.wakterm.desktop \
                 "${pkgdir}/usr/share/applications/org.wezfurlong.wakterm.desktop"
  install -Dm644 squashfs-root/usr/share/nautilus-python/extensions/wakterm-nautilus.py \
                 "${pkgdir}/usr/share/nautilus-python/extensions/wakterm-nautilus.py"
}
